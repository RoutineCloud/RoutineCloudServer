###############################################
# Example .env (not used at runtime)
#
# This file is provided as a template only. The application now
# loads configuration from two files in this directory:
#   - .env          -> defaults/template (this file)
#   - .env.local    -> your real, local overrides (NOT committed)
#
# Create .env.local by copying from this file:
#   cp .env .env.local
# Then adjust values as needed.
###############################################

# Database settings
# Uncomment and use this for direct DATABASE_URL configuration
#DATABASE_URL=postgresql://routine_user:routine_password@localhost:5432/routine_cloud

# SQLite database
DATABASE_URL=sqlite:///./routine_cloud.db

# API settings
SECRET_KEY=your_secret_key_here
ALLOWED_HOSTS=["localhost","127.0.0.1"]
ALLOW_ORIGINS=["http://localhost:8080","http://127.0.0.1:8080"]

# OIDC configuration
OIDC_ISSUER=https://issuer.zitadel.ch
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_JWKS_URL=